.dashboard-root {
    position: absolute;
    top: 12px;
    right: 12px;
    bottom: 12px;
    width: 400px;
    align-items: flex-end;
}

.toggle-tab {
    background-color: rgba(18, 18, 18, 0.88);
    color: rgb(220, 220, 220);
    border-radius: 5px;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.18);
    padding: 5px 12px;
    font-size: 12px;
    margin-bottom: 4px;
    -unity-font-style: bold;
    cursor: link;
}

.toggle-tab:hover {
    background-color: rgba(40, 40, 40, 0.92);
    border-color: rgba(255, 255, 255, 0.3);
}

.dashboard-panel {
    background-color: rgba(14, 14, 14, 0.90);
    border-radius: 6px;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.12);
    flex: 1;
    width: 400px;
    padding: 8px;
}

.dashboard-header {
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 6px;
    border-bottom-width: 1px;
    border-color: rgba(255, 255, 255, 0.1);
    margin-bottom: 6px;
}

.dashboard-title {
    font-size: 13px;
    color: rgb(210, 210, 210);
    -unity-font-style: bold;
    flex: 1;
}

.reset-button {
    background-color: rgba(180, 60, 60, 0.7);
    color: rgb(240, 210, 210);
    border-radius: 4px;
    border-width: 1px;
    border-color: rgba(255, 100, 100, 0.3);
    padding: 3px 10px;
    font-size: 11px;
    cursor: link;
}

.reset-button:hover {
    background-color: rgba(210, 70, 70, 0.85);
    border-color: rgba(255, 120, 120, 0.5);
}

.dashboard-foldout > Toggle {
    color: rgb(190, 190, 190);
    font-size: 11px;
    -unity-font-style: bold;
    margin-top: 2px;
    background-color: rgba(255, 255, 255, 0.04);
    border-radius: 3px;
    padding: 2px 4px;
}

FloatField,
IntegerField {
    margin-top: 2px;
}

FloatField > Label,
IntegerField > Label {
    color: rgb(170, 170, 170);
    min-width: 120px;
    font-size: 11px;
}

FloatField > #unity-text-input,
IntegerField > #unity-text-input {
    background-color: rgba(255, 255, 255, 0.06);
    color: rgb(240, 240, 240);
    border-color: rgba(255, 255, 255, 0.14);
    border-radius: 3px;
    font-size: 11px;
}

FloatField:hover > #unity-text-input,
IntegerField:hover > #unity-text-input {
    border-color: rgba(255, 255, 255, 0.28);
}

.vec3-row {
    flex-direction: row;
    align-items: center;
    margin-top: 2px;
}

.vec3-label {
    color: rgb(170, 170, 170);
    min-width: 120px;
    font-size: 11px;
}

.vec3-component {
    flex: 1;
    margin-left: 3px;
}

.vec3-component > Label {
    min-width: 8px;
    color: rgb(130, 130, 130);
    font-size: 11px;
}
